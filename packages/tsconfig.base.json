{
  "target": "es2016",
  "module": "commonjs",
  "esModuleInterop": true,
  "forceConsistentCasingInFileNames": true,
  "emitDecoratorMetadata": true,
  "experimentalDecorators": true,
  "strict": true,
  "skipLibCheck": true,
  "compilerOptions": {
    "outDir": "./build",
    "rootDir": "./src",
    "typeRoots" : ["./node_modules/@types", "./typings"]
  },
  "exclude": ["node_modules"]
}
