{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@telegramjs/common": ["./packages/common"],
      "@telegramjs/common/*": ["./packages/common/*"],
      "@telegramjs/core": ["./packages/core"],
      "@telegramjs/core/*": ["./packages/core/*"]
    },
    "include": ["packages/**/*"],
    "exclude": ["node_modules"]
  }
}
